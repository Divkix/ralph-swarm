{
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/swarm-watcher.sh",
            "statusMessage": "Checking swarm state..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/hooks/scripts/load-context.sh",
            "statusMessage": "Loading swarm context..."
          }
        ]
      }
    ]
  }
}
